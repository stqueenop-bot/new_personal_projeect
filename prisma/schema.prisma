// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  PARTIAL
  FAILED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  EXPIRED
  MANUAL_REVIEW
}

enum SmmProvider {
  SUPPORTIVE
  IND
}

model User {
  id        String   @id @default(uuid())
  mobile    String?  @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@map("users")
}

model Order {
  id          String      @id @default(uuid())
  serviceId   Int
  serviceName String?
  link        String
  quantity    Int
  amount      Float
  status      OrderStatus @default(PENDING)
  remark      String?
  userId      String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  provider    SmmProvider @default(SUPPORTIVE)

  user     User?     @relation(fields: [userId], references: [id])
  payment  Payment?
  smmOrder SmmOrder?

  @@map("orders")
}

model Payment {
  id             String        @id @default(uuid())
  zapupiOrderId  String        @unique
  orderId        String        @unique
  amount         Float
  status         PaymentStatus @default(PENDING)
  paymentUrl     String?
  utr            String?
  customerMobile String?
  zapupiTxnId    String?
  failureReason  String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

model SmmOrder {
  id         String      @id @default(uuid())
  orderId    String      @unique
  smmOrderId String?
  serviceId  Int
  provider   SmmProvider @default(SUPPORTIVE)
  link       String
  quantity   Int
  status     OrderStatus @default(PENDING)
  startCount Int?
  remains    Int?
  charge     Float?
  errorMsg   String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@map("smm_orders")
}

model Banner {
  id        String   @id @default(uuid())
  imageUrl  String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("banners")
}

model SpecialOffer {
  id          String   @id @default(uuid())
  serviceSlug String
  title       String
  badge       String   @default("LIVE")
  description String?
  serviceId   Int?
  quantity    Int?
  price       Float?
  active      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("special_offers")
}

model Spend {
  id        String   @id @default(uuid())
  category  String
  amount    Float
  note      String?
  date      DateTime
  createdAt DateTime @default(now())

  @@map("spends")
}

model AdminEmail {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@map("admin_emails")
}

model ApprovedGroup {
  id        String   @id @default(uuid())
  chatId    String   @unique
  title     String?
  createdAt DateTime @default(now())

  @@map("approved_groups")
}

model FailedOrderMessage {
  messageId Float    @id
  orderId   String
  createdAt DateTime @default(now())

  @@map("failed_order_messages")
}
