# ===========================
# Server
# ===========================
PORT=3000
NODE_ENV=development

# ===========================
# Database (PostgreSQL)
# ===========================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/smm_backend"

# ===========================
# ZapUPI Payment Gateway
# ===========================
ZAPUPI_TOKEN_KEY=your_zapupi_token_key_here
ZAPUPI_SECRET_KEY=your_zapupi_secret_key_here
ZAPUPI_API_URL=https://api.zapupi.com/api

# ===========================
# RabbitMQ
# ===========================
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# ===========================
# Telegram Bot
# ===========================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id

# ===========================
# Supportive SSM Panel
# ===========================
SSM_API_URL=https://supportivesmm.com/api/v2
SSM_API_KEY=your_ssm_panel_api_key_here

# ===========================
# Frontend
# ===========================
FRONTEND_URL=http://localhost:3001

# ===========================
# Security
# ===========================
# Optional: API key to protect your endpoints
API_AUTH_KEY=your_secret_api_auth_key

# Optional: ZapUPI webhook secret (if your panel provides one)
ZAPUPI_WEBHOOK_SECRET=
