# ===========================
# Server
# ===========================
PORT=3000
NODE_ENV=development

# ===========================
# Database (PostgreSQL)
# ===========================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/smm_backend"

# ===========================
# ZapUPI Payment Gateway
# ===========================
ZAPUPI_TOKEN_KEY=your_zapupi_token_key_here
ZAPUPI_SECRET_KEY=your_zapupi_secret_key_here
ZAPUPI_API_URL=https://api.zapupi.com/api

# ===========================
# RabbitMQ
# ===========================
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# ===========================
# Telegram — Main Bot (Success/Order Notifications)
# ===========================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id

# ===========================
# Telegram — Failed Orders Bot (Manual approval with /y command)
# ===========================
TELEGRAM_FAILED_BOT_TOKEN=your_failed_bot_token_from_botfather
TELEGRAM_FAILED_CHAT_ID=your_failed_orders_chat_id

# ===========================
# Supportive SSM Panel
# ===========================
SSM_API_URL=https://supportivesmm.com/api/v2
SSM_API_KEY=your_ssm_panel_api_key_here

# ===========================
# IND SMM Panel
# ===========================
IND_SMM_API_URL=https://indianprovider.com/api/v2
IND_SMM_API_KEY=your_ind_smm_api_key_here

# ===========================
# Frontend
# ===========================
FRONTEND_URL=http://localhost:3001

# ===========================
# Security
# ===========================
API_AUTH_KEY=your_secret_api_auth_key
ZAPUPI_WEBHOOK_SECRET=
ZAPUPI_WEBHOOK_IPS=
