{
    "compilerOptions": {
        "module": "CommonJS",
        "moduleResolution": "Node",
        "target": "ES2023",
        "outDir": "dist",
        "rootDir": "./",
        "strict": false,
        "esModuleInterop": true,
        "allowJs": true,
        "skipLibCheck": true,
        "types": ["node"]
    },
    "include": [
        "src/**/*",
        "lib/**/*",
        "generated/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}